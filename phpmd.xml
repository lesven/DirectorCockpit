<?xml version="1.0"?>
<ruleset name="DirectorCockpit"
         xmlns="http://pmd.sf.net/ruleset/1.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sf.net/ruleset/1.0.0 http://pmd.sf.net/ruleset_xml_schema.xsd"
         xsi:noNamespaceSchemaLocation="http://pmd.sf.net/ruleset_xml_schema.xsd">

    <description>DirectorCockpit PHPMD Regeln</description>

    <!-- ─── Code Size ───────────────────────────────────────────── -->
    <rule ref="rulesets/codesize.xml">
        <exclude name="CyclomaticComplexity"/>
        <exclude name="ExcessiveParameterList"/>
    </rule>
    <rule ref="rulesets/codesize.xml/CyclomaticComplexity">
        <properties>
            <property name="reportLevel" value="9"/>
        </properties>
    </rule>
    <rule ref="rulesets/codesize.xml/ExcessiveParameterList">
        <properties>
            <property name="minimum" value="11"/>
        </properties>
    </rule>

    <!-- ─── Design ──────────────────────────────────────────────── -->
    <rule ref="rulesets/design.xml">
        <!-- StaticAccess: PHP 8.1 Enum::tryFrom() ist idiomatisch, kein echtes Problem -->
        <exclude name="StaticAccess"/>
        <exclude name="CouplingBetweenObjects"/>
    </rule>
    <rule ref="rulesets/design.xml/CouplingBetweenObjects">
        <properties>
            <property name="maximum" value="23"/>
        </properties>
    </rule>

    <!-- ─── Naming ───────────────────────────────────────────────── -->
    <rule ref="rulesets/naming.xml">
        <!-- Kurze Variablen wie $id, $em, $kw, $e, $i sind in PHP/Symfony Konvention -->
        <exclude name="ShortVariable"/>
        <!-- Domänensprache ($eintrittswahrscheinlichkeit) tolerieren -->
        <exclude name="LongVariable"/>
    </rule>

    <!-- ─── Unused Code ──────────────────────────────────────────── -->
    <rule ref="rulesets/unusedcode.xml">
        <!--
          UnusedFormalParameter: Symfony-Interfaces (Security-Handler, EventListener, Controller)
          schreiben Parameter vor, die intern nicht genutzt werden. Das ist kein Code-Smell,
          sondern Interface-Contract-Pflicht. Beispiele: AuthenticationFailureHandler,
          AuthenticationSuccessHandler. Die Regel erzeugt zu viele False Positives.
        -->
        <exclude name="UnusedFormalParameter"/>
    </rule>

    <!-- ─── Clean Code ───────────────────────────────────────────── -->
    <rule ref="rulesets/cleancode.xml">
        <!-- StaticAccess: Enums sind designed für statischen Zugriff -->
        <exclude name="StaticAccess"/>
    </rule>

    <!-- ─── Controversial ────────────────────────────────────────── -->
    <rule ref="rulesets/controversial.xml">
        <!-- 
          Superglobals-Ausschluss ist BERECHTIGT:
          • $_ENV/$_SERVER zu lesen ist NOTWENDIG für Runtime-Konfiguration (Feature-Flags, DB, API-Keys)
          • Es is gekapselt in getEnv() - ein zentraler, dokumentierter Ort
          • Das ist Standard in PHP-Frameworks (Symfony, Laravel): keine versteckte Abhängigkeit
          • PHPMD sieht Env-Vars als "Code-Smell", aber hier ist es legitime Architektur
        -->
        <exclude name="Superglobals"/>
    </rule>

</ruleset>
